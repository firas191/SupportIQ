# PostgreSQL
POSTGRES_USER=supportiq
POSTGRES_PASSWORD=firas
POSTGRES_DB=supportiq

# RabbitMQ
RABBITMQ_DEFAULT_USER=supportiq
RABBITMQ_DEFAULT_PASS=firas

# JWT (backend) — DOIT faire au moins 32 octets (256 bits) pour HS256
JWT_SECRET=generate-a-long-random-secret-at-least-32-bytes-please

# Premier compte ADMIN amorce au demarrage (seeder idempotent).
# Laisser vide en prod pour desactiver le seeding automatique.
ADMIN_EMAIL=admin@supportiq.local
ADMIN_PASSWORD=firas
ADMIN_FULL_NAME=Administrateur SupportIQ

# LLM providers (au moins un requis ; failover dans cet ordre)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
# Empiler plusieurs comptes pour contourner les quotas quotidiens (le générateur d'eval bascule
# automatiquement au 429) : suffixes numérotés OU liste séparée par des virgules. Ex :
# GROQ_API_KEY_2=gsk_deuxieme_compte
# GROQ_API_KEY=gsk_compte_a,gsk_compte_b

# Seuil d'escalade LLM du routeur de confiance
CONFIDENCE_THRESHOLD=0.80

# Webhook d'ingestion temps reel (S2-J4) : cle API + secret HMAC partages avec l'appelant.
WEBHOOK_API_KEY=dev-webhook-key
WEBHOOK_SECRET=dev-webhook-secret-change-in-prod
