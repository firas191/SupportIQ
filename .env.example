# PostgreSQL
POSTGRES_USER=supportiq
POSTGRES_PASSWORD=change-me
POSTGRES_DB=supportiq

# RabbitMQ
RABBITMQ_DEFAULT_USER=supportiq
RABBITMQ_DEFAULT_PASS=change-me

# JWT (backend) — DOIT faire au moins 32 octets (256 bits) pour HS256
JWT_SECRET=generate-a-long-random-secret-at-least-32-bytes-please

# Premier compte ADMIN amorce au demarrage (seeder idempotent).
# Laisser vide en prod pour desactiver le seeding automatique.
ADMIN_EMAIL=admin@supportiq.local
ADMIN_PASSWORD=change-me-admin
ADMIN_FULL_NAME=Administrateur SupportIQ

# LLM providers (au moins un requis ; failover dans cet ordre)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434

# Seuil d'escalade LLM du routeur de confiance
CONFIDENCE_THRESHOLD=0.80
